{
  "repository": "FileUni/FileUni-Project",
  "package": {
    "name": "fileuni",
    "description": "FileUni CLI distributed through npm with on-demand platform binary downloads.",
    "repository_directory": ".github/npm",
    "bin_name": "fileuni",
    "display_name": "FileUni CLI",
    "env_prefix": "FILEUNI_NPM",
    "npm_config_prefix": "fileuni"
  },
  "targets": [
    { "target": "x86_64-unknown-linux-gnu", "os": "linux", "arch": "x64", "libc": "gnu", "asset_name": "FileUni-cli-x86_64-linux-gnu.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "x86_64-unknown-linux-musl", "os": "linux", "arch": "x64", "libc": "musl", "asset_name": "FileUni-cli-x86_64-linux-musl.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "aarch64-unknown-linux-gnu", "os": "linux", "arch": "arm64", "libc": "gnu", "asset_name": "FileUni-cli-aarch64-linux-gnu.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "aarch64-unknown-linux-musl", "os": "linux", "arch": "arm64", "libc": "musl", "asset_name": "FileUni-cli-aarch64-linux-musl.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "i686-unknown-linux-gnu", "os": "linux", "arch": "ia32", "libc": "gnu", "asset_name": "FileUni-cli-x86_32-linux-gnu.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "i686-unknown-linux-musl", "os": "linux", "arch": "ia32", "libc": "musl", "asset_name": "FileUni-cli-x86_32-linux-musl.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "arm-unknown-linux-gnueabi", "os": "linux", "arch": "arm", "libc": "gnu", "asset_name": "FileUni-cli-arm-linux-gnu.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "armv7-unknown-linux-musleabihf", "os": "linux", "arch": "arm", "libc": "musl", "asset_name": "FileUni-cli-armv7-linux-musl.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "riscv64gc-unknown-linux-gnu", "os": "linux", "arch": "riscv64", "libc": "gnu", "asset_name": "FileUni-cli-riscv64gc-linux-gnu.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "powerpc64le-unknown-linux-gnu", "os": "linux", "arch": "ppc64", "libc": "gnu", "asset_name": "FileUni-cli-powerpc64le-linux-gnu.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "x86_64-pc-windows-msvc", "os": "win32", "arch": "x64", "asset_name": "FileUni-cli-x86_64-windows-msvc.exe.zip", "asset_format": "zip", "installed_rel_path": "fileuni.exe", "launch_strategy": "exec" },
    { "target": "i686-pc-windows-msvc", "os": "win32", "arch": "ia32", "asset_name": "FileUni-cli-x86_32-windows-msvc.exe.zip", "asset_format": "zip", "installed_rel_path": "fileuni.exe", "launch_strategy": "exec" },
    { "target": "x86_64-apple-darwin", "os": "darwin", "arch": "x64", "asset_name": "FileUni-cli-x86_64-macos-darwin.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "aarch64-apple-darwin", "os": "darwin", "arch": "arm64", "asset_name": "FileUni-cli-aarch64-macos-darwin.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "aarch64-linux-android", "os": "android", "arch": "arm64", "asset_name": "FileUni-cli-aarch64-android-cli.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "armv7-linux-androideabi", "os": "android", "arch": "arm", "asset_name": "FileUni-cli-armv7-android-cli.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "x86_64-linux-android", "os": "android", "arch": "x64", "asset_name": "FileUni-cli-x86_64-android-cli.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" },
    { "target": "x86_64-unknown-freebsd", "os": "freebsd", "arch": "x64", "asset_name": "FileUni-cli-x86_64-freebsd-freebsd.zip", "asset_format": "zip", "installed_rel_path": "fileuni", "launch_strategy": "exec" }
  ]
}
